# WHOOP MCP Server Environment Configuration
# Copy this to .env and configure as needed

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=

# Storage Configuration (optional - uses default ~/.whoop-mcp-server/)
# WHOOP_STORAGE_DIR=/custom/path/to/storage

# Development Configuration
# WHOOP_DEBUG=false
# WHOOP_CACHE_DURATION=300

# OAuth Configuration (for advanced users)
# OAUTH_BASE_URL=https://your-oauth-service.example.com

# WHOOP OAuth app credentials (used by setup.py and token refresh)
# WHOOP_CLIENT_ID=
# WHOOP_CLIENT_SECRET=

# Cloudflare bootstrap script environment (optional convenience)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_KV_NAMESPACE_ID=
